// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Cliente {
  id                     Int      @id @default(autoincrement())
  cnpj                   String   @unique
  razaoSocial            String
  nomeFantasia           String?
  telefone               String?
  cidade                 String?
  estado                 String?
  endereco               String?
  observacoes            String?
  fretePadrao            Decimal  @default(0) @db.Decimal(10, 2)
  vendedorId             Int?
  comissaoFixaPercentual Decimal? @db.Decimal(5, 2)
  ativo                  Boolean  @default(true)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  vendedor        Vendedor?             @relation(fields: [vendedorId], references: [id])
  precosEspeciais PrecoClienteProduto[]
  vendas          Venda[]
  cheques         Cheque[]
  pagamentos      Pagamento[]
  titulos         TituloReceber[]
  fretes          FreteMovimento[]

  @@index([ativo, razaoSocial])
}

model Produto {
  id          Int      @id @default(autoincrement())
  nome        String
  codigo      String   @unique
  precoPadrao Decimal  @db.Decimal(10, 2)
  unidade     String   @default("ton")
  ativo       Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  precosClientes PrecoClienteProduto[]
  itensVenda     ItemVenda[]
  movimentacoes  MovimentacaoEstoque[]
}

model PrecoClienteProduto {
  id        Int     @id @default(autoincrement())
  clienteId Int
  produtoId Int
  preco     Decimal @db.Decimal(10, 2)

  cliente Cliente @relation(fields: [clienteId], references: [id])
  produto Produto @relation(fields: [produtoId], references: [id])

  @@unique([clienteId, produtoId])
}

model Motorista {
  id        Int      @id @default(autoincrement())
  nome      String
  telefone  String?
  veiculo   String?
  placa     String?
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())

  vendas Venda[]
}

model Vendedor {
  id                 Int      @id @default(autoincrement())
  nome               String
  telefone           String?
  comissaoPercentual Decimal  @default(0) @db.Decimal(5, 2)
  ativo              Boolean  @default(true)
  createdAt          DateTime @default(now())

  clientes Cliente[]
  vendas   Venda[]
}

model Venda {
  id              Int      @id @default(autoincrement())
  clienteId       Int
  vendedorId      Int
  motoristaId     Int?
  // Frete: valor na venda é a fonte principal; FreteMovimento espelha/atualiza para histórico e tela Fretes.
  frete           Decimal  @default(0) @db.Decimal(10, 2)
  freteRecibo     Boolean  @default(false)  // recibo de frete emitido?
  freteReciboNum  String?                   // número do recibo de frete
  comissaoPercentualAplicado Decimal @default(0) @db.Decimal(5, 2)
  comissaoValor              Decimal @default(0) @db.Decimal(10, 2)
  valorTotal      Decimal  @db.Decimal(10, 2) // apenas produtos, sem frete
  dataVenda       DateTime @default(now())
  observacoes     String?
  createdAt       DateTime @default(now())

  cliente   Cliente    @relation(fields: [clienteId], references: [id])
  vendedor  Vendedor   @relation(fields: [vendedorId], references: [id])
  motorista Motorista? @relation(fields: [motoristaId], references: [id])

  itens         ItemVenda[]
  movimentacoes MovimentacaoEstoque[]
  cheques       Cheque[]
  pagamentos    Pagamento[]
  titulos       TituloReceber[]
  fretes        FreteMovimento[]

  @@index([clienteId, dataVenda])
  @@index([vendedorId, dataVenda])
}

model ItemVenda {
  id            Int     @id @default(autoincrement())
  vendaId       Int
  produtoId     Int
  quantidade    Decimal @db.Decimal(10, 3)
  precoUnitario Decimal @db.Decimal(10, 2)
  subtotal      Decimal @db.Decimal(10, 2)

  venda   Venda   @relation(fields: [vendaId], references: [id], onDelete: Cascade)
  produto Produto @relation(fields: [produtoId], references: [id])
}

model MovimentacaoEstoque {
  id         Int      @id @default(autoincrement())
  produtoId  Int
  tipo       String   // entrada, saida, ajuste, devolucao
  quantidade Decimal  @db.Decimal(10, 3)
  data       DateTime @default(now())
  observacao String?
  vendaId    Int?

  produto Produto @relation(fields: [produtoId], references: [id])
  venda   Venda?  @relation(fields: [vendaId], references: [id], onDelete: Cascade)

  @@index([produtoId, data])
  @@index([vendaId])
}

model Cheque {
  id              Int       @id @default(autoincrement())
  numeroOrdem     Int       @unique @default(autoincrement())
  clienteId       Int
  vendaId         Int?      // venda a que este cheque se refere
  valor           Decimal   @db.Decimal(10, 2)
  banco           String?
  numero          String?
  agencia         String?
  conta           String?
  dataRecebimento DateTime  @default(now())
  dataCompensacao DateTime?
  status          String    @default("a_receber") // a_receber, recebido, depositado
  observacoes     String?
  createdAt       DateTime  @default(now())

  cliente   Cliente    @relation(fields: [clienteId], references: [id])
  venda     Venda?     @relation(fields: [vendaId], references: [id], onDelete: SetNull)
  pagamento Pagamento?

  @@index([clienteId, status, dataRecebimento])
  @@index([vendaId])
}

model Pagamento {
  id          Int      @id @default(autoincrement())
  clienteId   Int
  vendaId     Int?
  tipo        String   // cheque, dinheiro, transferencia
  valor       Decimal  @db.Decimal(10, 2)
  data        DateTime @default(now())
  chequeId    Int?     @unique
  observacoes String?
  createdAt   DateTime @default(now())

  cliente Cliente @relation(fields: [clienteId], references: [id])
  venda   Venda?  @relation(fields: [vendaId], references: [id], onDelete: SetNull)
  cheque  Cheque? @relation(fields: [chequeId], references: [id])

  @@index([clienteId, data])
  @@index([vendaId, data])
}

model TituloReceber {
  id            Int      @id @default(autoincrement())
  clienteId     Int
  vendaId       Int?
  numero        String?
  vencimento    DateTime
  valorOriginal Decimal  @db.Decimal(10, 2)
  valorPago     Decimal  @default(0) @db.Decimal(10, 2)
  status        String   @default("aberto") // aberto, parcial, quitado
  observacoes   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  cliente Cliente @relation(fields: [clienteId], references: [id])
  venda   Venda?  @relation(fields: [vendaId], references: [id], onDelete: SetNull)

  @@index([clienteId, status, vencimento])
  @@index([vendaId])
}

// Movimento de frete (listagem, recibo, legados). Valor/recibo também existem em Venda; manter alinhados via API de venda.
model FreteMovimento {
  id         Int      @id @default(autoincrement())
  vendaId    Int? // opcional: fretes legados sem ordem vinculada no banco novo
  clienteId  Int
  valor      Decimal  @db.Decimal(10, 2)
  reciboEmitido Boolean @default(false)
  reciboNumero  String?
  reciboData DateTime? // data do recibo (pode diferir da data do movimento)
  data       DateTime @default(now())
  observacao String?
  createdAt  DateTime @default(now())

  venda   Venda?  @relation(fields: [vendaId], references: [id], onDelete: SetNull)
  cliente Cliente @relation(fields: [clienteId], references: [id])

  @@index([clienteId, data])
  @@index([vendaId])
}

// Parâmetros globais do sistema (regras comerciais/financeiras)
model ConfigSistema {
  id        Int      @id @default(autoincrement())
  chave     String   @unique
  valor     String
  updatedAt DateTime @updatedAt
}

/// Eventos de auditoria financeira (append-only). Ver política de retenção em `services/financeiroEventos.js`.
model FinanceiroEvento {
  id         Int      @id @default(autoincrement())
  tipo       String
  entidade   String
  entidadeId Int?
  clienteId  Int?
  vendaId    Int?
  chequeId   Int?
  pagamentoId Int?
  tituloId   Int?
  valor      Decimal? @db.Decimal(10, 2)
  payload    Json?
  createdAt  DateTime @default(now())

  @@index([tipo, createdAt])
  @@index([clienteId, createdAt])
  @@index([vendaId, createdAt])
  @@index([chequeId, createdAt])
}
