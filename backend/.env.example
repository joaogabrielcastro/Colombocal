# --- Desenvolvimento local (escolha UMA opção) ---
#
# Opção A — Docker (recomendado): na raiz do repositório rode `docker compose up -d`
# DATABASE_URL="postgresql://postgres:colombocal_dev@localhost:5432/colombocal_dev?schema=public"
#
# Opção B — Postgres instalado no Windows (mesmo formato, troque usuário/senha/banco)
# DATABASE_URL="postgresql://postgres:SUA_SENHA@localhost:5432/nome_do_banco?schema=public"
#
# Opção C — VPS/Coolify: host interno (postgresql-database-...) NÃO funciona no PC.
# Use túnel SSH ou "publicly available" no Coolify, ou use A/B para codar.
#
# --- Produção (Coolify): variável no painel do app, não commite ---
# DATABASE_URL="postgresql://..."
#
# Evita client Data Proxy/no-engine local pedindo prisma://
PRISMA_CLIENT_ENGINE_TYPE="binary"

PORT=3001

# Produção: origem exata do frontend (ex.: https://app.seudominio.com). Em dev pode omitir.
# CORS_ORIGIN="https://..."

# Limite de requisições (express-rate-limit)
# RATE_LIMIT_MAX_PER_WINDOW=600
# RATE_LIMIT_CNPJ_PER_MIN=25
